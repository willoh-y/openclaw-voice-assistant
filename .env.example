# OpenClaw Voice Assistant API Keys
# ==================================
#
# Copy this file to one of these locations:
#   - ~/.config/openclaw-voice-assistant/.env (recommended for production)
#   - $XDG_CONFIG_HOME/openclaw-voice-assistant/.env
#   - ./.env (for development, in the project directory)
#
# Or specify explicitly:
#   openclaw-voice-assistant --env-file /path/to/.env
#
# For NixOS with systemd, use EnvironmentFile:
#   services.openclaw-voice-assistant.environmentFile = "/run/secrets/openclaw-voice-assistant";
#
# For NixOS with agenix:
#   services.openclaw-voice-assistant.environmentFile = config.age.secrets.openclaw-voice-assistant.path;
#
# For NixOS with sops-nix:
#   services.openclaw-voice-assistant.environmentFile = config.sops.secrets.openclaw-voice-assistant.path;

# Deepgram API key for speech-to-text (STT)
# Only required when stt.provider is "deepgram"
# Get yours at: https://console.deepgram.com/
STT_API_KEY=your_deepgram_api_key_here

# ElevenLabs API key for text-to-speech (TTS)
# Only needed if using elevenlabs provider (default)
# Get yours at: https://elevenlabs.io/
# Set tts.provider to "edge" in config.yaml to use free Edge TTS instead
TTS_API_KEY=your_elevenlabs_api_key_here

# OpenClaw authentication token
# Get yours from your OpenClaw instance
OPENCLAW_TOKEN=your_openclaw_token_here
